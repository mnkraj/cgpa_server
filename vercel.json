{
    "version": 2,
    "builds": [{
      "src": "*.js",
      "use": "@vercel/node"
    }],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/"
      }
    ],
    "functions": {
    "api/test.js": {
      "maxDuration": 50 
    },
    "api/*.js": {
      "maxDuration": 50
    }
  }
  } 